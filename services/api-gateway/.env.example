# Server
NODE_ENV=development
PORT=3000

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:5173

# Service URLs (Docker container names or localhost)
USER_SERVICE_URL=http://user-service:3001
PROFILE_SERVICE_URL=http://profile-service:3002
CATALOG_SERVICE_URL=http://catalog-service:3003
INQUIRY_SERVICE_URL=http://inquiry-service:3004
PAYMENT_SERVICE_URL=http://payment-service:3005
REVIEW_SERVICE_URL=http://review-service:3006
NOTIFICATION_SERVICE_URL=http://notification-service:3007
MEDIA_SERVICE_URL=http://media-service:3008

# For local development (if services are running on localhost)
# USER_SERVICE_URL=http://localhost:3001
# PROFILE_SERVICE_URL=http://localhost:3002
# etc...

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60000
