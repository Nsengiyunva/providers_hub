# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://eventhub:eventhub123@localhost:5432/eventhub

# Redis
REDIS_URL=redis://localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092

# JWT
